# Copy this file to .env.local and fill in the values from your Supabase
# project. The real .env.local is git-ignored and must never be committed.

# Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Project Settings > API > Project API keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Project Settings > API > Project API keys > service_role (secret).
# Server-side only. Kept here for later; the practice run does not require it.
SUPABASE_SERVICE_ROLE_KEY=

# --- Email (Resend) ------------------------------------------------------
# Optional. When RESEND_API_KEY is empty, enquiries are logged to the server
# terminal instead of being sent, so the site still works in development.
#
# Resend > API Keys > Create API Key
RESEND_API_KEY=
# The from address.
#  - No-DNS option (Wix domain): sign up to Resend with info@splashnswim.net
#    and set this to onboarding@resend.dev.
#  - Verified-domain option: use an address on your verified domain, e.g.
#    noreply@splashnswim.net.
EMAIL_FROM_ADDRESS=onboarding@resend.dev
# Where website enquiries are delivered.
ENQUIRY_NOTIFY_EMAIL=info@splashnswim.net
